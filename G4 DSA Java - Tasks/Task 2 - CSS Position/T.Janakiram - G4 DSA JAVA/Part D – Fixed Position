        /* Fixed Header */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: steelblue;
            color: white;
            text-align: center;
            padding: 15px;
        }

        /* Scrollable Content */
        .content {
            margin-top: 70px;
            padding: 20px;
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: crimson;
            color: white;
            padding: 12px 18px;
            text-decoration: none;
            border-radius: 5px;
        }
